{
  "name": "nexus",
  "version": "1.1.0",
  "private": true,
  "description": "Nexus — AI Coding Agent Desktop App. Free, local, open source. Actually builds things.",
  "author": {
    "name": "Eulogik",
    "email": "team@nexus.ai",
    "url": "https://github.com/eulogik"
  },
  "license": "MIT",
  "homepage": "https://nexus.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/eulogik/nexus.git",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/eulogik/nexus/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "llm",
    "open-source",
    "desktop-app",
    "tauri",
    "rust",
    "typescript",
    "openrouter",
    "gpt",
    "claude",
    "gemini",
    "copilot-alternative",
    "cursor-alternative",
    "claude-code-alternative",
    "developer-tools",
    "productivity",
    "agentic",
    "agent-loop",
    "mcp",
    "model-context-protocol",
    "git",
    "automation",
    "code-generation",
    "code-review",
    "devin-alternative",
    "bolt-alternative",
    "lovable-alternative",
    "v0-alternative",
    "swe-bench",
    "swe-agent"
  ],
  "categories": [
    "Developer Tools",
    "Productivity",
    "Artificial Intelligence"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=nexus-cli",
    "build:desktop": "pnpm --filter nexus-desktop tauri build",
    "dev": "turbo run dev --parallel",
    "dev:desktop": "pnpm --filter nexus-desktop tauri dev",
    "dev:cli": "pnpm --filter nexus-cli dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "release:desktop": "pnpm --filter nexus-desktop tauri build",
    "release:npm": "pnpm publish --filter=nexus-ai --filter=nexus-core --filter=nexus-sdk",
    "release": "tsx scripts/release.ts",
    "doctor": "tsx apps/nexus-cli/src/index.ts doctor",
    "nexus": "tsx apps/nexus-cli/src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.0",
    "sharp": "^0.35.2",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "zod": "^3.24.0"
  }
}
